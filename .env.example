# Environment variables for the Virtual Lab application
# Copy this file to .env and customize the values for your environment

# API Configuration
# For Docker/Nginx deployments, `/api/v1/*` is proxied through the same origin.
REACT_APP_API_URL=/api/v1

# Auth0 Configuration (legacy, optional)
REACT_APP_AUTH0_DOMAIN=your-auth0-domain.example.com
REACT_APP_AUTH0_CLIENT_ID=your-auth0-public-client-id

# Maps API Key (optional)
REACT_APP_MAPS_API=your_maps_api_key_here

# Port for the application (used in docker-compose)
PORT=3000
