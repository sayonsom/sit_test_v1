# Local Development Environment Variables (No GCP Dependencies)
ENVIRONMENT=local

# PostgreSQL Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aligndb
DB_USER=alignuser
DB_PASSWORD=alignpass

# Local Storage Configuration (replaces Google Cloud Storage)
LOCAL_STORAGE_PATH=/code/local_storage
STORAGE_BUCKET_NAME=align-hvl-2024-release1

# Application Settings
PORT=8080
