# ─────────────────────────────────────────────────────────
# SIT Virtual HV Laboratory — Local Deployment Config
# ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# Then run:
#   ./start_full.sh
# ─────────────────────────────────────────────────────────

# OpenAI API key (required for AI features: rephrase, fun facts)
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY

# Frontend port (default: 3000)
# FRONTEND_PORT=3000

# ─── Site URLs (IMPORTANT for production/UAT) ────────────
# Set these to your actual domain when running behind a reverse proxy.
# For local development, leave as http://localhost:3000
TOOL_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── LTI 1.3 / Brightspace (required for student access) ─
CLIENT_ID=REPLACE_WITH_BRIGHTSPACE_CLIENT_ID
DEPLOYMENT_ID=REPLACE_WITH_BRIGHTSPACE_DEPLOYMENT_ID
ISSUER=https://xsitestg.singaporetech.edu.sg
AUTHORIZATION_ENDPOINT=https://xsitestg.singaporetech.edu.sg/d2l/lti/authenticate
KEY_SET_URL=https://xsitestg.singaporetech.edu.sg/d2l/.well-known/jwks

# ─── Staff/Admin ADFS login (optional) ──────────────────
# Leave blank to disable staff login via Microsoft AD.
# REACT_APP_AAD_CLIENT_ID=
# REACT_APP_AAD_TENANT_ID=
# REACT_APP_AAD_AUTHORITY=
# REACT_APP_AAD_REDIRECT_URI=
# REACT_APP_AAD_SCOPES=
# REACT_APP_AAD_ALLOWED_GROUP_IDS=
# REACT_APP_AAD_ALLOWED_ROLES=
# REACT_APP_AAD_ALLOWED_EMAIL_DOMAIN=

# ─── Optional ────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
