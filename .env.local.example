# ─────────────────────────────────────────────────────────
# SIT Virtual HV Laboratory — Local Deployment Config
# ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# Then run:
#   ./start_full.sh
# ─────────────────────────────────────────────────────────

# OpenAI API key (required for AI features: rephrase, fun facts)
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY

# Frontend port (default: 3000)
# FRONTEND_PORT=3000

# ─── Site URL (IMPORTANT for production/UAT) ─────────────
# Set this to your actual domain when running behind a reverse proxy.
# Leave as localhost for local development.
SITE_URL=http://localhost:3000

# ─── LTI / Brightspace (required for student access) ─────
# CLIENT_ID=73f5925a-df31-473e-a2b9-a6916d63bbf0
# DEPLOYMENT_ID=REPLACE_WITH_BRIGHTSPACE_DEPLOYMENT_ID

# ─── Staff/Admin ADFS login (optional) ──────────────────
# Leave blank to disable staff login via Microsoft AD.
# REACT_APP_AAD_CLIENT_ID=
# REACT_APP_AAD_TENANT_ID=
# REACT_APP_AAD_AUTHORITY=
# REACT_APP_AAD_REDIRECT_URI=
# REACT_APP_AAD_SCOPES=
# REACT_APP_AAD_ALLOWED_GROUP_IDS=
# REACT_APP_AAD_ALLOWED_ROLES=
# REACT_APP_AAD_ALLOWED_EMAIL_DOMAIN=
